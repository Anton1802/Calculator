<Calculator>:

    input: input

    TextInput:
        cols: 1
        id: input
        pos: 0, 1100
        font_size: '90sp'
        size_hint: 1.0, 1.0
        size: 720, 310
        halign: 'right'
        readonly: True
        focus: False

    GridLayout:
        cols: 4
        spacing: 3
        size: 720, 1000
        Button:
            id: btn_с
            text: 'С'
            font_size: 50
            on_press: root.reset()
        Button:
            font_size: 50
            id: btn_devide
            text: '/'
            on_press: root.formula_add('/')
        Button:
            font_size: 50
            id: btn_multiply
            text: '*'
            on_press: root.formula_add('*')
        Button:
            font_size: 50
            id: btn_clear
            text: '<'
            on_press: root.clear()

        Button:
            font_size: 50
            id: btn_7
            text: '7'
            on_press: root.formula_add('7')
        Button:
            font_size: 50
            id: btn_8
            text: '8'
            on_press: root.formula_add('8')
        Button:
            font_size: 50
            id: btn_9
            text: '9'
            on_press: root.formula_add('9')
        Button:
            font_size: 50
            id: btn_minus
            text: '-'
            on_press: root.formula_add('-')

        Button:
            font_size: 50
            id: btn_4
            text: '4'
            on_press: root.formula_add('4')
        Button:
            font_size: 50
            id: btn_5
            text: '5'
            on_press: root.formula_add('5')
        Button:
            font_size: 50
            id: btn_6
            text: '6'
            on_press: root.formula_add('6')
        Button:
            font_size: 50
            id: btn_plus
            text: '+'
            on_press: root.formula_add('+')

        Button:
            font_size: 50
            id: btn_1
            text: '1'
            on_press: root.formula_add('1')
        Button:
            font_size: 50
            id: btn_2
            text: '2'
            on_press: root.formula_add('2')
        Button:
            font_size: 50
            id: btn_3
            text: '3'
            on_press: root.formula_add('3')
        Button:
            font_size: 50
            id: btn_history
            text: 'H'
            on_release: root.show_history()
        Button:
            font_size: 50
            id: btn_procent
            text: '%'
            on_press: root.formula_add('/100', '%')

        Button:
            font_size: 50
            id: btn_zero
            text: '0'
            on_press: root.formula_add('0')
        Button:
            font_size: 50
            id: btn_zap
            text: '.'
            on_press: root.formula_add('.')
        Button:
            font_size: 50
            id: btn_ravno
            text: '='
            on_press:
                root.start_operation()
